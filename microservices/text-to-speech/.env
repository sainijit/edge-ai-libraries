# Text To Speech - environment overrides for docker compose.
#
# Copy this file to .env and adjust as needed:
#
#   cp .env.example .env
#
# To make the container run as your host user (recommended so that
# models/, storage/, and .cache/huggingface/ stay writable from both
# Docker and standalone runs), set:
#
#   LOCAL_UID=$(id -u)  # e.g. 1000
#   LOCAL_GID=$(id -g)  # e.g. 1000
#   RENDER_GID=$(stat -c '%g' /dev/dri/renderD128)  # e.g. 992
#
# If unset, docker-compose.yml falls back to 1000:1000, which also matches
# the image's default runtime user. For GPU runs, RENDER_GID must match the
# host render node group so the non-root container can open /dev/dri/renderD*.

LOCAL_UID=1000
LOCAL_GID=1000
RENDER_GID=992