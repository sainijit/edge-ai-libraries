# Service Configuration
SERVICE_NAME=semantic-search-agent
SERVICE_VERSION=1.0.0
LOG_LEVEL=INFO
API_PORT=8080
METRICS_PORT=9090

# Proxy Configuration (uncomment and set if behind corporate proxy)
# HTTP_PROXY=http://proxy.company.com:8080
# HTTPS_PROXY=http://proxy.company.com:8080
# NO_PROXY=localhost,127.0.0.1,.local
# http_proxy=http://proxy.company.com:8080
# https_proxy=http://proxy.company.com:8080
# no_proxy=localhost,127.0.0.1,.local

# Matching Configuration
# Set to 'exact' for no VLM, 'semantic' for VLM-only, 'hybrid' for both
DEFAULT_MATCHING_STRATEGY=exact  # Options: exact, semantic, hybrid
CONFIDENCE_THRESHOLD=0.85
MAX_RETRIES=2

# VLM Backend Configuration (OPTIONAL - only needed if using semantic/hybrid matching)
# Options: ovms (remote OVMS server), openvino_local (local inference), openai (cloud API)
VLM_BACKEND=ovms

# OVMS Configuration (REQUIRED if VLM_BACKEND=ovms)
# Provide your external OVMS endpoint and model name
# Example: OVMS_ENDPOINT=http://your-ovms-host:8000
OVMS_ENDPOINT=
OVMS_MODEL_NAME=
OVMS_TIMEOUT=30

# OpenVINO Local Configuration (REQUIRED if VLM_BACKEND=openvino_local)
# Provide path to your local model
OPENVINO_MODEL_PATH=
OPENVINO_DEVICE=GPU
OPENVINO_MAX_NEW_TOKENS=512
OPENVINO_TEMPERATURE=0.0

# OpenAI Configuration (REQUIRED if VLM_BACKEND=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=100

# Cache Configuration
CACHE_ENABLED=true
CACHE_BACKEND=memory  # Options: memory, redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
CACHE_TTL=3600

# Metrics
PROMETHEUS_ENABLED=true

# Configuration File Paths (optional - defaults to config/ directory)
# CONFIG_DIR=./config
# ORDERS_FILE=./config/orders.json
# INVENTORY_FILE=./config/inventory.json
