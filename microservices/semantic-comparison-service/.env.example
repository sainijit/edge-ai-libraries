# Service Configuration
SERVICE_NAME=semantic-search-agent
SERVICE_VERSION=1.0.0
LOG_LEVEL=INFO
API_PORT=8080
METRICS_PORT=9090

# Proxy Configuration (uncomment and set if behind corporate proxy)
# HTTP_PROXY=http://proxy.company.com:8080
# HTTPS_PROXY=http://proxy.company.com:8080
# NO_PROXY=localhost,127.0.0.1,.local
# http_proxy=http://proxy.company.com:8080
# https_proxy=http://proxy.company.com:8080
# no_proxy=localhost,127.0.0.1,.local

# VLM Backend Configuration
VLM_BACKEND=ovms  # Options: ovms, openvino_local, openai

# OVMS Configuration
OVMS_ENDPOINT=http://ovms-vlm:8000
OVMS_MODEL_NAME=Qwen2-VL-2B-Instruct
OVMS_TIMEOUT=30

# OpenVINO Local Configuration
OPENVINO_MODEL_PATH=/models/Qwen2-VL-2B-Instruct
OPENVINO_DEVICE=GPU
OPENVINO_MAX_NEW_TOKENS=512
OPENVINO_TEMPERATURE=0.0

# OpenAI Configuration (fallback)
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=100

# Cache Configuration
CACHE_ENABLED=true
CACHE_BACKEND=memory  # Options: memory, redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
CACHE_TTL=3600

# Matching Configuration
DEFAULT_MATCHING_STRATEGY=hybrid  # Options: exact, semantic, hybrid
CONFIDENCE_THRESHOLD=0.85
MAX_RETRIES=2

# Metrics
PROMETHEUS_ENABLED=true
