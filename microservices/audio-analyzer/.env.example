# Audio Analyzer - environment overrides for docker compose.
#
# Copy this file to .env and adjust as needed:
#
#   cp .env.example .env
#
# To make the container run as your host user (recommended so that
# models/, chunks/, storage/, and .cache/huggingface/ stay writable
# from both Docker and standalone runs), set:
#
#   LOCAL_UID=$(id -u)  # e.g. 1000
#   LOCAL_GID=$(id -g)  # e.g. 1000
#
# If unset, docker-compose.yml falls back to 1000:1000, which also matches
# the image's default runtime user.

LOCAL_UID=1000
LOCAL_GID=1000
